{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "claude/docs/*.md",
    "claude/*/README.md"
  ],
  "permission": {
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "lsp": "allow"
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "*.elf",
      "*.hex",
      "*.bin"
    ]
  },
  "autoupdate": false
}
